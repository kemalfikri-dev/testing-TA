<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Arsip Orders - Pesen.In</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="page-title mb-0">Arsip Orders</h2>
      <a href="/orders" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">Kembali ke Orders</a>
    </div>

    <div class="table-glass-container shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle border-0">
          <thead>
            <tr>
              <th>No</th>
              <th>Nama User</th>
              <th>Menu</th>
              <th>Qty</th>
              <th>Subtotal</th>
              <th>Status</th>
              <th>Tanggal</th>
              <% if (user && user.role === 'admin') { %>
              <th class="text-center">Aksi</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach((order, index) => { %>
            <tr>
              <td class="text-muted"><%= index + 1 %></td>
              <td class="fw-bold text-dark"><%= order.name %></td>
              <td><%= order.menu_name %></td>   
              <td><span class="badge bg-secondary rounded-pill"><%= order.quantity %></span></td>    
              <td class="text-success fw-bold">Rp <%= Number(order.subtotal).toLocaleString('id-ID') %></td>
              <td>
                <% 
                  let badgeClass = 'bg-secondary';
                  if(order.status === 'pending') badgeClass = 'bg-warning text-dark';
                  if(order.status === 'paid') badgeClass = 'bg-info text-dark';
                  if(order.status === 'preparing') badgeClass = 'bg-primary';
                  if(order.status === 'ready') badgeClass = 'bg-success';
                  if(order.status === 'cancel') badgeClass = 'bg-danger';
                %>
                <span class="badge <%= badgeClass %> rounded-pill px-2 py-1"><%= order.status.toUpperCase() %></span>
              </td>     
              <td class="small text-muted"><%= order.date %></td>  
              <% if (user && user.role === 'admin') { %>     
              <td class="text-center">
                <div class="d-flex flex-wrap justify-content-center gap-1">
                  <!-- Restore -->
                  <form action="/orders/restore/<%= order.orders_id %>" method="POST" class="m-0">
                    <button class="btn btn-success btn-sm btn-sm-custom">Kembalikan</button>
                  </form>

                  <!-- Hard delete -->
                  <form action="/orders/hard-delete/<%= order.orders_id %>" method="POST" class="m-0">
                    <button class="btn btn-danger btn-sm btn-sm-custom">Hapus Permanen</button>
                  </form>
                </div>
              </td>
              <% } %>
            </tr>
            <% }) %>
            <% if (orders.length === 0) { %>
            <tr>
              <td colspan="8" class="text-center text-muted py-4">Belum ada pesanan yang diarsipkan.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>
