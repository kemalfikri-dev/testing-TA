<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Orders</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
      <h4>orders</h4>
      <a href="/orders/create" class="btn btn-primary">+ Tambah Menu</a>
    </div>

    <table class="table table-bordered">
      <thead>
        <tr>
          <th>No</th>
          <th>Nama User</th>
          <th>Menu</th>
          <th>Quantity</th>
          <th>Subtotal</th>
          <th>Status</th>
          <th>Tanggal</th>
          <% if (user && user.role === 'admin') { %>
          <th>Aksi</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach((order, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= order.name %></td>
          <td><%= order.menu_name %></td>   
          <td><%= order.quantity %></td>    
          <td>Rp <%= Number(order.subtotal).toLocaleString('id-ID') %></td> <!-- subtotal -->
          <td><%= order.status %></td>     
          <td><%= order.date %></td>  
          <% if (user && user.role === 'admin') { %>     
          <td>
            <!-- Update status -->
          <form action="/orders/update-status/<%= order.orders_id %>" method="POST" style="display:inline">
            <select name="status">
              <option>pending</option>
              <option>paid</option>
              <option>preparing</option>
              <option>ready</option>
              <option>cancel</option>
            </select>
            <button class="btn btn-primary btn-sm">Update</button>
          </form>

          <!-- Soft delete -->
          <form action="/orders/soft-delete/<%= order.orders_id %>" method="POST" style="display:inline">
            <button class="btn btn-secondary btn-sm">Arsip</button>
          </form>

          <!-- Hard delete -->
          <form action="/orders/hard-delete/<%= order.orders_id %>" method="POST" style="display:inline">
            <button class="btn btn-danger btn-sm">Hapus</button>
          </form>
          </td>
          <% } %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>