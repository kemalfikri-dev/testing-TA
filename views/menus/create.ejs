<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tambah Menu - Pesen.In</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-5">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-6">
        <div class="glass-card p-5">
          <div class="text-center mb-4">
            <h3 class="fw-bold text-dark">Tambah Menu Baru</h3>
            <p class="text-muted small">Silakan lengkapi form di bawah ini untuk menambahkan menu baru.</p>
          </div>

          <!-- Tampilkan error kalau ada -->
          <% if (error) { %>
            <div class="alert alert-danger rounded-pill py-2 text-sm"><%= error %></div>
          <% } %>

          <form action="/menus/create" method="POST">
            <div class="mb-3">
              <label class="form-label fw-bold text-muted small">Nama Menu</label>
              <input type="text" name="menu_name" class="form-control" placeholder="Contoh: Nasi Goreng Spesial" required>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold text-muted small">Kategori</label>
              <select name="categories_id" class="form-select">
                <% categories.forEach(category => { %>
                  <option value="<%= category.categories_id %>">
                    <%= category.categories_name %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold text-muted small">Harga (Rp)</label>
              <input type="number" name="price" class="form-control" placeholder="Contoh: 25000" min="0" required>
            </div>
            <div class="mb-4">
              <label class="form-label fw-bold text-muted small">Deskripsi</label>
              <textarea name="description" class="form-control" rows="3" placeholder="Masukkan deskripsi singkat menu" required></textarea>
            </div>
            
            <div class="d-flex gap-2 mt-4">
              <a class="btn btn-secondary w-50 py-2 rounded-pill" href="/menus">Batal</a>
              <button type="submit" class="btn btn-primary w-50 py-2 rounded-pill">Simpan Menu</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

</body>
</html>