<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Menus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
      <h4>Menus</h4>
      <% if (user && user.role === 'admin') { %>
      <a href="/menus/create" class="btn btn-primary">+ Tambah Menu</a>
      <% } %>
    </div>

    <!-- Search -->
    <form action="/menus" method="GET" class="mb-3">
      <div class="input-group">
        <input type="text" name="search" class="form-control" 
               placeholder="Cari menu..." value="<%= search %>">
        <button class="btn btn-outline-secondary">Cari</button>
      </div>
    </form>

    <table class="table table-bordered">
      <thead>
        <tr>
          <th>No</th>
          <th>Nama Menu</th>
          <th>Kategori</th>
          <th>Harga</th>
          <th>Deskripsi</th>
          <% if (user && user.role === 'admin') { %>
          <th>Aksi</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% menus.forEach((menu, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= menu.menu_name %></td>
          <td><%= menu.categories_name %></td>
          <td>Rp <%= menu.price %></td>
          <td><%= menu.description %></td>
          <% if (user && user.role === 'admin') { %>
          <td>
            <a href="/menus/edit/<%= menu.menus_id %>" class="btn btn-warning btn-sm">Edit</a>
            <form action="/menus/soft-delete/<%= menu.menus_id %>" method="POST" style="display:inline">
              <button class="btn btn-secondary btn-sm">Arsip</button>
            </form>
            <form action="/menus/hard-delete/<%= menu.menus_id %>" method="POST" style="display:inline">
              <button class="btn btn-danger btn-sm">Hapus</button>
            </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>