<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Menus - Pesen.In</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="page-title mb-0">Menus</h2>
      <% if (user && user.role === 'admin') { %>
      <a href="/menus/create" class="btn btn-primary rounded-pill px-4 shadow-sm">+ Tambah Menu</a>
      <% } %>
    </div>

    <!-- Search -->
    <div class="row mb-4">
      <div class="col-md-6 col-lg-4">
        <form action="/menus" method="GET">
          <div class="input-group search-glass">
            <span class="input-group-text border-0 bg-transparent text-muted">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
              </svg>
            </span>
            <input type="text" name="search" class="form-control" placeholder="Cari menu..." value="<%= search %>">
            <button class="btn btn-primary px-4">Cari</button>
          </div>
        </form>
      </div>
    </div>

    <div class="table-glass-container shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle border-0">
          <thead>
            <tr>
              <th>No</th>
              <th>Nama Menu</th>
              <th>Kategori</th>
              <th>Harga</th>
              <th>Deskripsi</th>
              <% if (user && user.role === 'admin') { %>
              <th class="text-center">Aksi</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% menus.forEach((menu, index) => { %>
            <tr>
              <td class="text-muted"><%= index + 1 %></td>
              <td class="fw-bold text-dark"><%= menu.menu_name %></td>
              <td><span class="badge bg-light text-primary border border-primary-subtle rounded-pill"><%= menu.categories_name %></span></td>
              <td class="text-success fw-bold">Rp <%= Number(menu.price).toLocaleString('id-ID') %></td>
              <td class="text-muted small"><%= menu.description %></td>
              <% if (user && user.role === 'admin') { %>
              <td class="text-center">
                <div class="d-flex justify-content-center gap-2">
                  <a href="/menus/edit/<%= menu.menus_id %>" class="btn btn-warning btn-sm btn-sm-custom text-white">Edit</a>
                  <form action="/menus/soft-delete/<%= menu.menus_id %>" method="POST" class="m-0">
                    <button class="btn btn-secondary btn-sm btn-sm-custom">Arsip</button>
                  </form>
                  <form action="/menus/hard-delete/<%= menu.menus_id %>" method="POST" class="m-0">
                    <button class="btn btn-danger btn-sm btn-sm-custom">Hapus</button>
                  </form>
                </div>
              </td>
              <% } %>
            </tr>
            <% }) %>
            <% if (menus.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center text-muted py-4">Tidak ada menu yang ditemukan.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>