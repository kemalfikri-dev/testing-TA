<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <title>Menus</title>
  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

  <style>
    /* Styling Kustom Mengikuti Referensi Gambar */
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f8f9fc;
      /* Warna background abu-abu terang sesuai gambar */
      color: #333;
    }

    .page-subtitle {
      font-size: 1rem;
      color: #6c757d;
      margin-bottom: 0.2rem;
    }

    .page-title {
      font-weight: 700;
      color: #2D3436;
      font-size: 2.2rem;
    }

    /* Search Bar */
    .search-container {
      max-width: 400px;
      flex-grow: 1;
    }

    .search-input {
      border-radius: 0 12px 12px 0;
      box-shadow: none !important;
      border: 1px solid #e0e0e0;
      border-left: none;
    }

    .search-icon-wrapper {
      border-radius: 12px 0 0 12px;
      border: 1px solid #e0e0e0;
      border-right: none;
      background-color: #ffffff;
      padding-left: 1.2rem;
    }

    /* Buttons */
    .btn-add {
      background-color: #F4B41A;
      color: #fff;
      border-radius: 12px;
      font-weight: 500;
      padding: 0.5rem 1.2rem;
      transition: all 0.2s;
      border: none;
    }

    .btn-add:hover {
      background-color: #e5a817;
      color: #fff;
      transform: translateY(-2px);
    }

    .btn-arsip {
      background-color: #fff;
      color: #6c757d;
      border-radius: 12px;
      font-weight: 500;
      padding: 0.5rem 1.2rem;
      border: 1px solid #e0e0e0;
      transition: all 0.2s;
    }

    .btn-arsip:hover {
      background-color: #f8f9fa;
      color: #495057;
    }

    /* Menu Card */
    .menu-card {
      border: none;
      border-radius: 20px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
      transition: all 0.3s ease;
      background-color: #ffffff;
      padding: 0.6rem;
      aspect-ratio: 4 / 7;
      display: flex;
      flex-direction: column;
    }

    .menu-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    }

    .menu-emoji-container {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      aspect-ratio: 1 / 1;
      background-color: #f8f9fa;
      border-radius: 14px;
      margin-bottom: 0.8rem;
      font-size: 5rem;
    }

    .badge-category {
      background-color: #FDF3E1;
      color: #EAA023;
      font-weight: 500;
      border-radius: 8px;
    }

    .price-text {
      color: #2D3436;
      font-weight: 700;
      font-size: 1.1rem;
    }
    
    .price-currency {
      color: #F4B41A;
      margin-right: 4px;
    }

    .desc-text {
      color: #6c757d;
      font-size: 0.8rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Dropdown / Edit Button */
    .dropdown-btn {
      color: #2D3436;
      background: #ffffff;
      border: none;
      border-radius: 50%;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      font-size: 1.1rem;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
    }

    .dropdown-btn:hover {
      background: #f8f9fa;
      color: #000;
      transform: scale(1.05);
    }
  </style>
</head>

<body>
  <%- include('../partials/navbar') %>

  <div class="container py-4">

      <!-- Action Buttons (Admin Only) -->
      <% if (user && user.role==='admin' ) { %>
      <div class="d-flex justify-content-end mb-4 gap-2">
        <a href="/menus/arsip" class="btn btn-arsip shadow-sm d-flex align-items-center gap-2">
          <i class="bi bi-archive"></i> Cek Arsip
        </a>
        <a href="/menus/create" class="btn btn-add shadow-sm d-flex align-items-center gap-2">
          Add New Menu
        </a>
      </div>
      <% } %>

      <!-- Section Title -->
      <div class="text-center mb-4 mt-3">
        <h4 class="fw-bold" style="color: #2D3436;">Daftar Item Menu</h4>
      </div>

      <!-- Search Bar -->
      <div class="d-flex justify-content-start mb-4">
        <form action="/menus" method="GET" class="search-container">
          <div class="input-group">
            <span class="input-group-text search-icon-wrapper" id="search-addon">
              <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" name="search" class="form-control search-input py-2" placeholder="Search"
              value="<%= search %>" aria-describedby="search-addon">
          </div>
        </form>
      </div>

        <!-- Grid Cards -->
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-4 mb-5">
          <% menus.forEach((menu, index)=> { %>
            <div class="col">
              <div class="card h-100 menu-card position-relative">
                
                <% if (user && user.role==='admin' ) { %>
                  <!-- Titik Tiga (Action Menu) -->
                  <div class="dropdown position-absolute top-0 end-0 mt-2 me-2" style="z-index: 1050;">
                    <button class="dropdown-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Menu Edit">
                      <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius: 12px;">
                      <li><a class="dropdown-item fw-medium py-2" href="/menus/edit/<%= menu.menus_id %>"><i
                            class="bi bi-pencil-square me-2 text-warning"></i>Edit</a></li>
                      <li>
                        <form action="/menus/soft-delete/<%= menu.menus_id %>" method="POST" class="m-0">
                          <button type="submit" class="dropdown-item fw-medium py-2"><i
                              class="bi bi-box-arrow-down me-2 text-secondary"></i>Arsipkan</button>
                        </form>
                      </li>
                      <li>
                        <hr class="dropdown-divider">
                      </li>
                      <li>
                        <form action="/menus/hard-delete/<%= menu.menus_id %>" method="POST" class="m-0">
                          <button type="submit" class="dropdown-item fw-medium py-2 text-danger"><i
                              class="bi bi-trash me-2"></i>Hapus Permanen</button>
                        </form>
                      </li>
                    </ul>
                  </div>
                <% } %>

                <!-- Emoji Section -->
                <% 
                  const emojis = ['🍔', '🍕', '🌭', '🍟', '🥪', '🌮', '🌯', '🥗', '🥘', '🍝', '🍜', '🍲', '🍛', '🍣', '🍱', '🥟', '🍤', '🍘', '🍙', '🍚', '🍗', '🥩', '🍢', '🍡', '🍧', '🍨', '🍦', '🍰', '🎂', '🍮', '🍭', '🍬', '🍫', '🍿', '🍩', '🍪', '🥤', '🧋', '🧃', '🧉', '☕', '🍵'];
                  const emoji = emojis[(menu.menus_id || 0) % emojis.length] || '🍽️';
                %>
                <div class="menu-emoji-container" title="<%= menu.menu_name %>">
                  <%= emoji %>
                </div>

                <!-- Card Body -->
                <div class="card-body pt-0 px-3 pb-3 text-center">
                  <!-- Title -->
                  <h5 class="card-title fw-bold text-truncate mb-1" style="color: #2D3436;">
                    <%= menu.menu_name %>
                  </h5>

                  <!-- Category -->
                  <div class="mb-2">
                    <span class="badge-category" style="font-size: 0.7rem; padding: 0.25rem 0.6rem;">
                      <%= menu.categories_name %>
                    </span>
                  </div>

                  <!-- Price -->
                  <h5 class="price-text mb-3">
                    <span class="price-currency">Rp</span><%= menu.price %>
                  </h5>

                  <!-- Description -->
                  <p class="desc-text mb-0 mx-auto" style="max-width: 95%;">
                    <%= menu.description %>
                  </p>
                </div>
              </div>
            </div>
            <% }) %>
        </div>
      </div>
      <!-- Bootstrap JS Bundle -->
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>