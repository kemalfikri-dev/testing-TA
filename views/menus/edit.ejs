<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Menu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-5">
        <div class="card shadow">
          <div class="card-body p-4">
            <h4 class="card-title text-center mb-4">Edit Menu</h4>

            <!-- Tampilkan error kalau ada -->
            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/menus/edit/<%= menu.menus_id %>" method="POST">
              <div class="mb-3">
                <label>Nama Menu</label>
                <input type="text" name="menu_name" class="form-control" value="<%= menu.menu_name %>" required>
                <label>Harga</label>
                <input type="number" name="price" class="form-control" value="<%= menu.price %>" required>
                <label>Deskripsi</label>
                <input type="text" name="description" class="form-control" value="<%= menu.description %>" required>
                <label>Kategori</label>
                <select name="categories_id" class="form-control">
                  <% categories.forEach(category => { %>
                    <option value="<%= category.categories_id %>"
                      <%= category.categories_id === menu.categories_id ? 'selected' : '' %>>
                      <%= category.categories_name %>
                    </option>

                    <% }) %>
                  </select>
              </div>
              <button type="submit" class="btn btn-primary w-100">Submit</button>
              <a class="btn btn-warning w-100 mt-2" href="/menus">Kembali</a>
            </form>
          </div>
          
        </div>
      </div>
    </div>
  </div>

</body>
</html>