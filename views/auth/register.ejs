<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - Pesen.In</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="auth-container container my-5">
    <div class="row justify-content-center w-100">
      <div class="col-md-5 col-lg-4">
        <div class="glass-card text-center p-5">
          <div class="mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="var(--primary-color)" class="bi bi-person-plus mb-3" viewBox="0 0 16 16">
              <path d="M6 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H1s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C9.516 10.68 8.289 10 6 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
              <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5z"/>
            </svg>
            <h3 class="fw-bold text-dark">Create an Account</h3>
            <p class="text-muted small">Join us and start ordering today.</p>
          </div>

          <!-- Tampilkan error kalau ada -->
          <% if (error) { %>
            <div class="alert alert-danger rounded-pill py-2 text-sm"><%= error %></div>
          <% } %>

          <form action="/auth/register" method="POST" class="text-start">
            <div class="mb-3">
              <label class="form-label text-muted small fw-bold">Nama Lengkap</label>
              <input type="text" name="name" class="form-control" placeholder="John Doe" required>
            </div>
            <div class="mb-3">
              <label class="form-label text-muted small fw-bold">Email Address</label>
              <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
            </div>
            <div class="mb-4">
              <label class="form-label text-muted small fw-bold">Password</label>
              <input type="password" name="password" class="form-control" placeholder="Create a strong password" required>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill">Create Account</button>
          </form>

          <p class="text-center mt-4 small text-muted">
            Sudah punya akun? <a href="/auth/login" class="fw-bold text-primary text-decoration-none">Login di sini</a>
          </p>
        </div>
      </div>
    </div>
  </div>

</body>
</html>