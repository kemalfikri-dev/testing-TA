<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Pesen.In</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  <div class="auth-container container">
    <div class="row justify-content-center w-100">
      <div class="col-md-5 col-lg-4">
        <div class="glass-card text-center p-5">
          <div class="mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="var(--primary-color)" class="bi bi-box-seam mb-3" viewBox="0 0 16 16">
              <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923zM2.623 3.836l5.377 2.15 5.377-2.15-5.377-2.15z"/>
            </svg>
            <h3 class="fw-bold text-dark">Welcome Back</h3>
            <p class="text-muted small">Please enter your details to sign in.</p>
          </div>

          <!-- Tampilkan error kalau ada -->
          <% if (error) { %>
            <div class="alert alert-danger rounded-pill py-2 text-sm"><%= error %></div>
          <% } %>

          <form action="/auth/login" method="POST" class="text-start">
            <div class="mb-3">
              <label class="form-label text-muted small fw-bold">Email Address</label>
              <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
            </div>
            <div class="mb-4">
              <label class="form-label text-muted small fw-bold">Password</label>
              <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill">Sign In</button>
          </form>

          <p class="text-center mt-4 small text-muted">
            Belum punya akun? <a href="/auth/register" class="fw-bold text-primary text-decoration-none">Register di sini</a>
          </p>
        </div>
      </div>
    </div>
  </div>

</body>
</html>