<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Categories</title>
  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f8f9fc;
      color: #333;
    }

    .page-title {
      font-weight: 700;
      color: #2D3436;
      font-size: 2.2rem;
    }

    .btn-add {
      background-color: #F4B41A;
      color: #fff;
      border-radius: 12px;
      font-weight: 500;
      padding: 0.5rem 1.2rem;
      transition: all 0.2s;
      border: none;
    }

    .btn-add:hover {
      background-color: #e5a817;
      color: #fff;
      transform: translateY(-2px);
    }

    /* Category Card */
    .category-card {
      border: none;
      border-radius: 20px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
      transition: all 0.3s ease;
      background-color: #ffffff;
      text-align: center;
      padding: 2.5rem 1rem 2rem 1rem;
      position: relative;
    }

    .category-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    }

    .category-icon {
      font-size: 3.5rem;
      color: #F4B41A;
      margin-bottom: 1rem;
    }

    .category-title {
      font-weight: 600;
      color: #2D3436;
      font-size: 1.1rem;
    }

    /* Dropdown */
    .dropdown-btn {
      color: #6c757d;
      background: none;
      border: none;
      padding: 0;
      font-size: 1.2rem;
      transition: color 0.2s;
    }

    .dropdown-btn:hover {
      color: #333;
    }
  </style>
</head>

<body>
  <%- include('../partials/navbar') %>

  <div class="container py-4">
    <!-- Header / Actions -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 mt-3 gap-3">
      <h4 class="page-title mb-0">Categories</h4>
      <% if (user && user.role === 'admin') { %>
        <a href="/categories/create" class="btn btn-add shadow-sm d-flex align-items-center gap-2">
          Add New Category
        </a>
      <% } %>
    </div>

    <!-- Cards Grid -->
    <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-4 mb-5">
      <% categories.forEach((category, index) => { %>
        <div class="col">
          <div class="card h-100 category-card">
            <% if (user && user.role === 'admin') { %>
              <div class="dropdown position-absolute top-0 end-0 mt-3 me-3">
                <button class="dropdown-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="bi bi-three-dots"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius: 12px;">
                  <li>
                    <a class="dropdown-item fw-medium py-2" href="/categories/edit/<%= category.categories_id %>">
                      <i class="bi bi-pencil-square me-2 text-warning"></i>Edit
                    </a>
                  </li>
                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li>
                    <form action="/categories/delete/<%= category.categories_id %>" method="POST" class="m-0">
                      <button type="submit" class="dropdown-item fw-medium py-2 text-danger">
                        <i class="bi bi-trash me-2"></i>Hapus Permanen
                      </button>
                    </form>
                  </li>
                </ul>
              </div>
            <% } %>
            
            <div class="category-icon">
              <!-- Ikon statis karena tidak ada field icon di DB -->
              <i class="bi bi-grid-fill"></i>
            </div>
            <h5 class="category-title mb-0"><%= category.categories_name %></h5>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Bootstrap JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>