<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Categories - Pesen.In</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="page-title mb-0">Categories</h2>
      <% if (user && user.role === 'admin') { %>
      <a href="/categories/create" class="btn btn-primary rounded-pill px-4 shadow-sm">+ Tambah</a>
      <% } %>
    </div>

    <div class="table-glass-container shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle border-0">
          <thead>
            <tr>
              <th width="10%">No</th>
              <th>Nama Kategori</th>
              <% if (user && user.role === 'admin') { %>
              <th width="20%" class="text-center">Aksi</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% categories.forEach((category, index) => { %>
            <tr>
              <td class="text-muted"><%= index + 1 %></td>
              <td class="fw-bold text-dark"><span class="badge bg-light text-primary border border-primary-subtle rounded-pill px-3 py-2"><%= category.categories_name %></span></td>
              <% if (user && user.role === 'admin') { %>
              <td class="text-center">
                <div class="d-flex justify-content-center gap-2">
                  <a href="/categories/edit/<%= category.categories_id %>" class="btn btn-warning btn-sm btn-sm-custom text-white">Edit</a>
                  <form action="/categories/delete/<%= category.categories_id %>" method="POST" class="m-0">
                    <button type="submit" class="btn btn-danger btn-sm btn-sm-custom">Hapus</button>
                  </form>
                </div>
              </td>
              <% } %>
            </tr>
            <% }) %>
            <% if (categories.length === 0) { %>
            <tr>
              <td colspan="3" class="text-center text-muted py-4">Tidak ada kategori yang ditemukan.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</body>
</html>