<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Categories</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
      <h4>Categories</h4>
      <a href="/categories/create" class="btn btn-primary">+ Tambah</a>
    </div>

    <table class="table table-bordered">
      <thead>
        <tr>
          <th>No</th>
          <th>Nama Kategori</th>
          <% if (user && user.role === 'admin') { %>
          <th>Aksi</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% categories.forEach((category, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= category.categories_name %></td>
          <% if (user && user.role === 'admin') { %>
          <td>
            <a href="/categories/edit/<%= category.categories_id %>" class="btn btn-warning btn-sm">Edit</a>
            <form action="/categories/delete/<%= category.categories_id %>" method="POST" style="display:inline">
              <button type="submit" class="btn btn-danger btn-sm">Hapus</button>
            </form>
          </td>
          <% } %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</body>
</html>