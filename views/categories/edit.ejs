<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Kategori - Pesen.In</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container my-5">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-5">
        <div class="glass-card p-5">
          <div class="text-center mb-4">
            <h3 class="fw-bold text-dark">Edit Kategori</h3>
            <p class="text-muted small">Ubah nama kategori yang ada.</p>
          </div>

          <!-- Tampilkan error kalau ada -->
          <% if (error) { %>
            <div class="alert alert-danger rounded-pill py-2 text-sm"><%= error %></div>
          <% } %>

          <form action="/categories/edit/<%= category.categories_id %>" method="POST">
            <div class="mb-4">
              <label class="form-label fw-bold text-muted small">Nama Kategori</label>
              <input type="text" name="categories_name" class="form-control" value="<%= category.categories_name %>" required>
            </div>
            
            <div class="d-flex gap-2 mt-4">
              <a class="btn btn-secondary w-50 py-2 rounded-pill" href="/categories">Batal</a>
              <button type="submit" class="btn btn-primary w-50 py-2 rounded-pill">Simpan Perubahan</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

</body>
</html>